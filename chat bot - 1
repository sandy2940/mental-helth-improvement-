  // Send email if EmailJS is configured
  if(EMAILJS_SERVICE_ID && EMAILJS_TEMPLATE_ID && EMAILJS_PUBLIC_KEY && MONITOR_EMAIL){
    emailjs.init(EMAILJS_PUBLIC_KEY);
    emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, {
      to_email:   MONITOR_EMAIL,
      alert_time: alert.time,
      language:   alert.lang,
      message:    msg,
      keywords:   kws.join(', ') || 'crisis keyword detected',
    }).catch(()=>{});
  }
}

// ═══════════════════════════════════════════════════
//  THERAPY DATASET
// ═══════════════════════════════════════════════════
let therapyData = null;

async function loadTherapyDataset(){
  try{
    const res = await fetch('therapy_dataset.json');
    if(!res.ok) throw new Error('not found');
    therapyData = await res.json();
  }catch(e){
    // dataset not loaded — therapy cards simply won't show
    therapyData = null;
  }
}

function getTherapyForEmotion(emotion){
  if(!therapyData) return null;
  const bucket = therapyData.therapies[emotion];
  if(!bucket || !bucket.techniques.length) return null;
  // Pick a random technique so it feels fresh each time
  const idx = Math.floor(Math.random() * bucket.techniques.length);
  return { meta: bucket, technique: bucket.techniques[idx] };
}

function renderTherapyCard(emotion){
  const result = getTherapyForEmotion(emotion);
  if(!result) return null;

  const { meta, technique } = result;

  const card = document.createElement('div');
  card.className = 'therapy-card';
  card.style.cssText = `background:${meta.color};border-color:${meta.border};color:${meta.text}`;

  const stepsHtml = technique.steps.map((s,i)=>
    `<li><span class="step-num">${i+1}.</span><span>${s}</span></li>`
  ).join('');

  card.innerHTML = `
