<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MindEase — AI Mental Health Companion</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
<!-- EmailJS for crisis alerts -->
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<!-- CryptoJS for AES-256 encryption -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.2.0/crypto-js.min.js"></script>
<style>
:root{
  --sage:#7a9e7e;--sage-light:#a8c5ac;--sage-dark:#4a6e4f;
  --cream:#f5f0e8;--warm-white:#faf8f4;
  --charcoal:#2c2c2c;--muted:#7a7870;
  --border:rgba(44,44,44,0.12);
  --bot-bubble:#edeae3;--accent:#c17f5a;
  --danger:#e05252;--danger-bg:#fff5f5;--danger-border:#f5c0c0;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--warm-white);color:var(--charcoal);
  height:100dvh;display:flex;flex-direction:column;overflow:hidden}
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:radial-gradient(ellipse 80% 60% at 20% 10%,rgba(122,158,126,.08) 0%,transparent 60%),
  radial-gradient(ellipse 60% 80% at 80% 90%,rgba(193,127,90,.06) 0%,transparent 60%)}

/* ── HEADER ── */
header{position:relative;z-index:10;display:flex;align-items:center;justify-content:space-between;
  padding:13px 20px;border-bottom:1px solid var(--border);
  background:rgba(250,248,244,.97);backdrop-filter:blur(12px)}
.logo{display:flex;align-items:center;gap:9px}
.logo-icon{width:30px;height:30px;background:var(--sage);border-radius:50%;
  display:flex;align-items:center;justify-content:center;position:relative}
.logo-icon::after{content:'';width:11px;height:11px;background:var(--warm-white);border-radius:50%;position:absolute}
.logo-icon::before{content:'';width:19px;height:19px;border:2px solid rgba(250,248,244,.4);border-radius:50%;position:absolute}
.logo-text{font-family:'DM Serif Display',serif;font-size:19px;letter-spacing:-.3px}
.logo-text span{color:var(--sage-dark)}
.hright{display:flex;align-items:center;gap:7px}
.hbtn{background:transparent;border:1px solid var(--border);border-radius:20px;
  padding:4px 11px;font-size:12px;color:var(--muted);cursor:pointer;
  font-family:'DM Sans',sans-serif;transition:all .2s;display:flex;align-items:center;gap:4px}
.hbtn:hover{background:var(--cream);color:var(--charcoal)}
.hbtn.on{background:var(--sage);color:#fff;border-color:var(--sage)}
.hbtn.alert-btn{border-color:var(--danger);color:var(--danger)}
.hbtn.alert-btn:hover{background:var(--danger);color:#fff}
.alert-badge{background:var(--danger);color:#fff;border-radius:50%;
  width:16px;height:16px;font-size:10px;display:inline-flex;align-items:center;justify-content:center;font-weight:600}
.status-pill{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--muted);
  background:var(--cream);padding:4px 11px;border-radius:20px;border:1px solid var(--border)}
.sdot{width:6px;height:6px;border-radius:50%;background:#7ab87a;animation:pulse 2.5s ease-in-out infinite}
.sdot.off{background:var(--danger);animation:none}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.85)}}

/* ── LANG BAR ── */
.lang-bar{position:relative;z-index:9;background:var(--cream);border-bottom:1px solid var(--border);padding:7px 20px}
.lang-inner{max-width:700px;margin:0 auto;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.lang-lbl{font-size:12px;color:var(--muted);white-space:nowrap}
.lbtn{background:var(--warm-white);border:1px solid var(--border);border-radius:20px;
  padding:4px 13px;font-size:12px;cursor:pointer;font-family:'DM Sans',sans-serif;
  color:var(--charcoal);transition:all .15s}
.lbtn:hover{border-color:var(--sage)}
.lbtn.active{background:var(--sage);color:#fff;border-color:var(--sage)}

/* ── NLP BAR ── */
.nlp-bar{position:relative;z-index:8;max-height:0;overflow:hidden;transition:max-height .4s;
  background:#f9f7f2;border-bottom:1px solid var(--border)}
.nlp-bar.visible{max-height:50px}
.nlp-inner{max-width:700px;margin:0 auto;padding:7px 22px;display:flex;align-items:center;gap:7px;flex-wrap:wrap}
.pill{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:500}
.p-joy{background:#e8f5e9;color:#2e7d32}.p-sadness{background:#e3f2fd;color:#1565c0}
.p-anxiety{background:#fff8e1;color:#f57f17}.p-anger{background:#fce4ec;color:#880e4f}
.p-neutral{background:#f5f5f5;color:#616161}.p-lang{background:#ede7f6;color:#4527a0}
.p-kw{background:#e0f2f1;color:#00695c}.p-crisis{background:#ffebee;color:#b71c1c;font-weight:600}
.p-history{background:#e8eaf6;color:#283593}

/* ── HISTORY PANEL ── */
.history-panel{position:fixed;top:0;right:-360px;width:340px;height:100dvh;
  background:var(--warm-white);border-left:1px solid var(--border);z-index:100;
  display:flex;flex-direction:column;transition:right .3s ease;box-shadow:-4px 0 20px rgba(0,0,0,.06)}
.history-panel.open{right:0}
.hp-header{padding:16px 18px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;background:var(--cream)}
.hp-title{font-family:'DM Serif Display',serif;font-size:16px}
.hp-close{background:none;border:none;cursor:pointer;color:var(--muted);font-size:18px;line-height:1}
.hp-body{flex:1;overflow-y:auto;padding:14px}
.hp-body::-webkit-scrollbar{width:3px}
.hp-body::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.mood-chart{background:var(--cream);border-radius:12px;padding:14px;margin-bottom:14px}
.mood-chart-title{font-size:12px;color:var(--muted);margin-bottom:10px;font-weight:500}
.mood-bars{display:flex;gap:6px;align-items:flex-end;height:60px}
.mood-bar-col{display:flex;flex-direction:column;align-items:center;gap:3px;flex:1}
.mood-bar{width:100%;border-radius:4px 4px 0 0;min-height:4px;transition:height .3s}
.mood-bar-lbl{font-size:9px;color:var(--muted)}
.session-card{background:var(--cream);border-radius:10px;padding:12px;margin-bottom:10px;
  border:1px solid var(--border);cursor:pointer;transition:border-color .2s}
.session-card:hover{border-color:var(--sage)}
.sc-date{font-size:11px;color:var(--muted);margin-bottom:5px}
.sc-summary{font-size:13px;line-height:1.5;color:var(--charcoal)}
.sc-mood{display:inline-flex;align-items:center;gap:4px;margin-top:6px;
  background:var(--warm-white);border-radius:20px;padding:2px 8px;font-size:11px}
.no-history{text-align:center;color:var(--muted);font-size:13px;padding:24px 0}

/* ── MONITOR PANEL ── */
.monitor-panel{position:fixed;top:0;left:-380px;width:360px;height:100dvh;
  background:var(--warm-white);border-right:1px solid var(--border);z-index:100;
  display:flex;flex-direction:column;transition:left .3s ease;box-shadow:4px 0 20px rgba(0,0,0,.06)}
.monitor-panel.open{left:0}
.mp-header{padding:16px 18px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;background:#fff5f5}
.mp-title{font-family:'DM Serif Display',serif;font-size:16px;color:var(--danger)}
.mp-close{background:none;border:none;cursor:pointer;color:var(--muted);font-size:18px;line-height:1}
.mp-body{flex:1;overflow-y:auto;padding:14px}
.mp-body::-webkit-scrollbar{width:3px}
.mp-body::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.alert-card{background:#fff5f5;border:1px solid var(--danger-border);border-radius:10px;
  padding:12px;margin-bottom:10px;animation:fadeUp .3s ease}
.ac-time{font-size:11px;color:var(--danger);margin-bottom:5px;font-weight:500}
.ac-msg{font-size:13px;line-height:1.5;color:var(--charcoal);margin-bottom:6px}
.ac-keywords{display:flex;flex-wrap:wrap;gap:5px}
.ac-kw{background:#ffebee;color:#b71c1c;border-radius:20px;padding:2px 8px;font-size:11px;font-weight:500}
.ac-lang{background:#ede7f6;color:#4527a0;border-radius:20px;padding:2px 8px;font-size:11px}
.mp-empty{text-align:center;color:var(--muted);font-size:13px;padding:32px 0}
.mp-empty-icon{font-size:32px;margin-bottom:10px}
.mp-stats{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px}
.mp-stat{background:var(--cream);border-radius:8px;padding:10px;text-align:center}
.mp-stat-n{font-size:22px;font-weight:500;color:var(--charcoal)}
.mp-stat-l{font-size:11px;color:var(--muted)}
.mp-stat.danger .mp-stat-n{color:var(--danger)}
.clear-alerts{width:100%;background:transparent;border:1px solid var(--border);border-radius:8px;
  padding:8px;font-size:13px;color:var(--muted);cursor:pointer;font-family:'DM Sans',sans-serif;
  margin-top:8px;transition:all .2s}
.clear-alerts:hover{background:var(--cream)}

/* ── OVERLAY ── */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.25);z-index:99;display:none;backdrop-filter:blur(2px)}
.overlay.show{display:block}

/* ── CHAT ── */
.chat-wrap{position:relative;z-index:1;flex:1;overflow-y:auto;padding:22px 0;scroll-behavior:smooth}
.chat-wrap::-webkit-scrollbar{width:4px}
.chat-wrap::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.msgs{max-width:700px;margin:0 auto;padding:0 20px;display:flex;flex-direction:column;gap:15px}

.welcome{background:var(--cream);border:1px solid var(--border);border-radius:20px;
  padding:24px 28px;text-align:center;animation:fadeUp .5s ease both}
.welcome h2{font-family:'DM Serif Display',serif;font-size:22px;margin-bottom:7px}
.welcome h2 em{color:var(--sage-dark);font-style:italic}
.welcome p{font-size:14px;color:var(--muted);line-height:1.6;max-width:360px;margin:0 auto 16px}
.chips{display:flex;flex-wrap:wrap;gap:7px;justify-content:center}
.chip{background:var(--warm-white);border:1px solid var(--border);border-radius:20px;
  padding:6px 13px;font-size:12px;color:var(--charcoal);cursor:pointer;
  transition:all .2s;font-family:'DM Sans',sans-serif}
.chip:hover{background:var(--sage);color:#fff;border-color:var(--sage);transform:translateY(-1px)}

.mood-strip{display:flex;align-items:center;gap:7px;flex-wrap:wrap}
.ml{font-size:12px;color:var(--muted);white-space:nowrap}
.mb{background:var(--cream);border:1px solid var(--border);border-radius:8px;
  padding:4px 11px;font-size:13px;cursor:pointer;transition:all .15s;
  font-family:'DM Sans',sans-serif;color:var(--charcoal)}
.mb:hover,.mb.active{background:var(--sage-light);border-color:var(--sage)}

/* context notice */
.ctx-notice{background:#e8eaf6;border:1px solid #c5cae9;border-radius:10px;
  padding:9px 14px;font-size:12px;color:#283593;line-height:1.5;animation:fadeUp .3s ease}

.msg{display:flex;gap:9px;animation:fadeUp .3s ease both}
.msg.user{flex-direction:row-reverse}
.av{width:30px;height:30px;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;margin-top:2px}
.av.bot{background:var(--sage);color:#fff;font-family:'DM Serif Display',serif;font-size:13px}
.av.usr{background:var(--charcoal);color:#fff}
.av.speaking{animation:speakPulse .6s ease-in-out infinite alternate}
@keyframes speakPulse{from{box-shadow:0 0 0 0 rgba(122,158,126,.4)}to{box-shadow:0 0 0 8px rgba(122,158,126,0)}}
.bwrap{display:flex;flex-direction:column;gap:4px}
.bub{max-width:500px;padding:10px 14px;border-radius:16px;font-size:14px;line-height:1.65}
.msg.bot .bub{background:var(--bot-bubble);color:var(--charcoal);border-bottom-left-radius:4px}
.msg.user .bub{background:var(--charcoal);color:#f5f5f5;border-bottom-right-radius:4px}
.replay-btn{background:none;border:none;cursor:pointer;color:var(--muted);
  font-size:12px;padding:0;font-family:'DM Sans',sans-serif;transition:color .2s}
.replay-btn:hover{color:var(--sage-dark)}

.typing{display:none;align-items:center;gap:9px;animation:fadeUp .3s ease both}
.typing.show{display:flex}
.dots{background:var(--bot-bubble);border-radius:16px;border-bottom-left-radius:4px;
  padding:10px 14px;display:flex;gap:4px;align-items:center}
.dot{width:6px;height:6px;border-radius:50%;background:var(--muted);animation:bounce 1.2s ease-in-out infinite}
.dot:nth-child(2){animation-delay:.2s}.dot:nth-child(3){animation-delay:.4s}
@keyframes bounce{0%,80%,100%{transform:translateY(0);opacity:.4}40%{transform:translateY(-6px);opacity:1}}

/* ── INPUT ── */
.input-area{position:relative;z-index:10;padding:11px 20px 15px;
  background:rgba(250,248,244,.97);backdrop-filter:blur(12px);border-top:1px solid var(--border)}
.crisis-bar{display:none;max-width:700px;margin:0 auto 9px;background:#fff5f0;
  border:1px solid #f0c0a0;border-radius:11px;padding:9px 13px;font-size:13px;color:#8b4513;line-height:1.6}
.crisis-bar.show{display:block;animation:fadeUp .3s ease}
.crisis-bar strong{display:block;margin-bottom:3px}
.crisis-bar a{color:var(--accent);text-decoration:underline}
.err{display:none;max-width:700px;margin:0 auto 7px;background:#fff0f0;
  border:1px solid var(--danger-border);border-radius:9px;padding:7px 13px;font-size:13px;color:#a03030}
.err.show{display:block;animation:fadeUp .3s ease}
.iw{max-width:700px;margin:0 auto;display:flex;align-items:flex-end;gap:7px;
  background:var(--cream);border:1.5px solid var(--border);
  border-radius:20px;padding:7px 7px 7px 15px;transition:border-color .2s}
.iw:focus-within{border-color:var(--sage)}
#inp{flex:1;background:transparent;border:none;outline:none;
  font-family:'DM Sans',sans-serif;font-size:14px;color:var(--charcoal);
  resize:none;max-height:110px;line-height:1.5;padding:4px 0}
#inp::placeholder{color:var(--muted)}
#inp:disabled{opacity:.5;cursor:not-allowed}
.ib{width:34px;height:34px;border-radius:50%;border:1px solid var(--border);
  background:var(--cream);color:var(--muted);cursor:pointer;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .2s}
.ib:hover:not(:disabled){background:var(--sage-light);color:var(--sage-dark)}
.ib:disabled{opacity:.4;cursor:not-allowed}
.ib.listening{background:var(--accent);color:#fff;border-color:var(--accent);
  animation:micPulse 1s ease-in-out infinite}
@keyframes micPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.12)}}
#sbtn{width:34px;height:34px;border-radius:11px;border:none;background:var(--sage);
  color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;
  flex-shrink:0;transition:all .2s}
#sbtn:hover:not(:disabled){background:var(--sage-dark);transform:scale(1.05)}
#sbtn:disabled{opacity:.45;cursor:not-allowed}
.hint{max-width:700px;margin:5px auto 0;font-size:11px;color:var(--muted);text-align:center;opacity:.7}

/* ── THERAPY CARD ── */
.therapy-card{border-radius:14px;padding:14px 16px;margin-top:4px;
  border:1px solid;animation:fadeUp .4s ease both;max-width:500px}
.therapy-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.therapy-title{font-size:13px;font-weight:500;display:flex;align-items:center;gap:6px}
.therapy-meta{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px}
.therapy-tag{font-size:11px;padding:2px 8px;border-radius:20px;background:rgba(0,0,0,.06);font-weight:500}
.therapy-desc{font-size:13px;line-height:1.55;margin-bottom:10px;opacity:.85}
.therapy-steps{list-style:none;padding:0;margin:0 0 10px;display:flex;flex-direction:column;gap:5px}
.therapy-steps li{font-size:12px;line-height:1.5;padding:6px 10px;
  background:rgba(255,255,255,.5);border-radius:8px;display:flex;gap:8px;align-items:flex-start}
.step-num{font-weight:600;flex-shrink:0;font-size:11px;margin-top:1px}
.therapy-affirmation{font-size:12px;font-style:italic;opacity:.75;
  border-top:1px solid rgba(0,0,0,.08);padding-top:8px;line-height:1.5}
.therapy-toggle{background:none;border:none;cursor:pointer;font-size:12px;
  opacity:.6;font-family:'DM Sans',sans-serif;transition:opacity .2s;padding:0}
.therapy-toggle:hover{opacity:1}
.therapy-steps-wrap{overflow:hidden;transition:max-height .35s ease;max-height:0}
.therapy-steps-wrap.open{max-height:600px}
@keyframes crisisFlash{0%,100%{background:rgba(250,248,244,.97)}50%{background:#fff0f0}}
.crisis-flash{animation:crisisFlash .4s ease 3}

@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:600px){.bub{max-width:86%}.logo-text{font-size:17px}
  .history-panel,.monitor-panel{width:100%}}

/* ── LOCK SCREEN ── */
.lock-screen{position:fixed;inset:0;z-index:999;
  background:var(--warm-white);display:flex;align-items:center;justify-content:center;
  flex-direction:column;gap:0;animation:fadeUp .4s ease}
.lock-screen.hidden{display:none}
.lock-card{background:var(--cream);border:1px solid var(--border);border-radius:24px;
  padding:40px 36px;max-width:360px;width:90%;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,.06)}
.lock-icon{width:64px;height:64px;background:var(--sage);border-radius:50%;
  margin:0 auto 20px;display:flex;align-items:center;justify-content:center;position:relative}
.lock-icon::after{content:'';width:24px;height:24px;background:var(--warm-white);border-radius:50%;position:absolute}
.lock-icon::before{content:'';width:40px;height:40px;border:3px solid rgba(250,248,244,.4);border-radius:50%;position:absolute}
.lock-title{font-family:'DM Serif Display',serif;font-size:22px;margin-bottom:6px}
.lock-title em{color:var(--sage-dark);font-style:italic}
.lock-sub{font-size:13px;color:var(--muted);margin-bottom:24px;line-height:1.5}
.lock-input{width:100%;background:var(--warm-white);border:1.5px solid var(--border);
  border-radius:12px;padding:12px 16px;font-size:15px;font-family:'DM Sans',sans-serif;
  color:var(--charcoal);outline:none;text-align:center;letter-spacing:3px;
  transition:border-color .2s;margin-bottom:10px}
.lock-input:focus{border-color:var(--sage)}
.lock-input.error{border-color:var(--danger);animation:shake .3s ease}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}
.lock-btn{width:100%;background:var(--sage);color:#fff;border:none;border-radius:12px;
  padding:13px;font-size:15px;font-family:'DM Sans',sans-serif;cursor:pointer;
  transition:background .2s;font-weight:500;margin-bottom:10px}
.lock-btn:hover{background:var(--sage-dark)}
.lock-err{font-size:12px;color:var(--danger);min-height:18px}
.lock-note{font-size:11px;color:var(--muted);margin-top:16px;line-height:1.6;
  background:var(--warm-white);border-radius:8px;padding:10px}
.lock-note strong{display:block;margin-bottom:3px;color:var(--charcoal)}
/* Encrypted badge */
.enc-badge{display:inline-flex;align-items:center;gap:4px;background:#e8f5e9;color:#2e7d32;
  border-radius:20px;padding:3px 10px;font-size:11px;font-weight:500;margin-bottom:14px}
</style>
</head>
<body>

<!-- ── LOCK SCREEN ── -->
<div class="lock-screen" id="lock-screen">
  <div class="lock-card">
    <div class="lock-icon"></div>
    <div class="enc-badge">🔒 AES-256 Encrypted</div>
    <div class="lock-title">Mind<em>Ease</em></div>
    <div class="lock-sub" id="lock-sub">Your conversations are encrypted and private.<br>Enter your passphrase to continue.</div>
    <input class="lock-input" type="password" id="lock-pass" placeholder="Enter passphrase" autocomplete="off" maxlength="64"/>
    <div class="lock-err" id="lock-err"></div>
    <button class="lock-btn" id="lock-btn" onclick="submitPassphrase()">Unlock</button>
    <div class="lock-note">
      <strong>First time?</strong>
      Choose any passphrase — it will encrypt all your data. If you forget it, your stored history cannot be recovered (by design).
    </div>
  </div>
</div>

<header>
  <div class="logo">
    <div class="logo-icon"></div>
    <div class="logo-text">Mind<span>Ease</span></div>
  </div>
  <div class="hright">
    <!-- Monitor button (shows alert count) -->
    <button class="hbtn alert-btn" id="monitor-btn" onclick="openMonitor()">
      ⚠ Monitor <span class="alert-badge" id="alert-badge">0</span>
    </button>
    <button class="hbtn" id="history-btn" onclick="openHistory()">📋 History</button>
    <button class="hbtn" onclick="lockApp()">🔒 Lock</button>
    <button class="hbtn on" id="tts-btn" onclick="toggleTTS()">🔊 Voice</button>
    <button class="hbtn" onclick="clearChat()">Clear</button>
