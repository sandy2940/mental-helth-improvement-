}

function toggleSteps(btn){
  const card = btn.closest('.therapy-card');
  const wrap = card.querySelector('.therapy-steps-wrap');
  const open = wrap.classList.toggle('open');
  btn.textContent = open ? '▲ Hide steps' : '▼ Show steps';
}

const PASSPHRASE_HASH_KEY = 'mindease_ph';  // stores hash of passphrase (not passphrase itself)
let SESSION_KEY = null;   // in-memory only — cleared on lock

function encryptData(data, key){
  try{ return CryptoJS.AES.encrypt(JSON.stringify(data), key).toString(); }
  catch(e){ return null; }
}
function decryptData(cipher, key){
  try{
    const bytes = CryptoJS.AES.decrypt(cipher, key);
    return JSON.parse(bytes.toString(CryptoJS.enc.Utf8));
  }catch(e){ return null; }
}
function hashPassphrase(pass){
  return CryptoJS.SHA256(pass).toString();
}

// Encrypted localStorage wrappers
function secureGet(storageKey){
  if(!SESSION_KEY) return [];
  const raw = localStorage.getItem(storageKey);
  if(!raw) return [];
  const dec = decryptData(raw, SESSION_KEY);
  return Array.isArray(dec) ? dec : [];
}
function secureSet(storageKey, data){
  if(!SESSION_KEY) return;
  const enc = encryptData(data, SESSION_KEY);
  if(enc) localStorage.setItem(storageKey, enc);
}

// ═══════════════════════════════════════════════════
//  LOCK SCREEN
// ═══════════════════════════════════════════════════
function isFirstTime(){
  return !localStorage.getItem(PASSPHRASE_HASH_KEY);
}

function submitPassphrase(){
  const pass = document.getElementById('lock-pass').value.trim();
  const errEl = document.getElementById('lock-err');
  const input = document.getElementById('lock-pass');

  if(pass.length < 4){
    errEl.textContent = 'Passphrase must be at least 4 characters.';
    input.classList.add('error');
    setTimeout(()=>input.classList.remove('error'),400);
    return;
  }

  const hash = hashPassphrase(pass);

  if(isFirstTime()){
    // First launch — set passphrase
    localStorage.setItem(PASSPHRASE_HASH_KEY, hash);
    SESSION_KEY = pass;
    unlockApp();
  } else {
    // Returning — verify passphrase
    const storedHash = localStorage.getItem(PASSPHRASE_HASH_KEY);
    if(hash === storedHash){
      SESSION_KEY = pass;
      unlockApp();
    } else {
      errEl.textContent = 'Wrong passphrase. Try again.';
      input.value = '';
      input.classList.add('error');
      setTimeout(()=>{ input.classList.remove('error'); errEl.textContent=''; },1200);
    }
  }
}

function unlockApp(){
  document.getElementById('lock-screen').classList.add('hidden');
  document.getElementById('lock-pass').value='';
  document.getElementById('lock-err').textContent='';
  // Update lock sub text for next time
  document.getElementById('lock-sub').textContent='Your conversations are encrypted and private.\nEnter your passphrase to continue.';
  updateAlertBadge();
}

function lockApp(){
  SESSION_KEY = null;
  window.speechSynthesis.cancel();
  // Update sub text to show it's a returning user
  if(!isFirstTime()){
    document.getElementById('lock-sub').textContent='Your conversations are encrypted and private.\nEnter your passphrase to continue.';
    document.getElementById('lock-btn').textContent='Unlock';
  }
  document.getElementById('lock-screen').classList.remove('hidden');
  setTimeout(()=>document.getElementById('lock-pass').focus(),300);
}

// Enter key on lock screen
document.getElementById('lock-pass').addEventListener('keydown',function(e){
  if(e.key==='Enter') submitPassphrase();
});

// Update sub text and button based on first time or not
function initLockScreen(){
