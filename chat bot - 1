// ═══════════════════════════════════════════════════
let currentSessionMoods = [];  // track moods this session

function getSessions(){ return secureGet(SESSIONS_KEY); }

function saveSession(){
  if(!history.length) return;
  const sessions = getSessions();
  const userMsgs = history.filter(m=>m.role==='user').map(m=>m.content);
  const allText  = userMsgs.join(' ');
  const emotion  = detectEmotion(allText);
  const kws      = extractKW(allText).slice(0,6);
  const summary  = userMsgs.slice(0,2).map(m=>m.length>60?m.slice(0,60)+'…':m).join(' / ');
  const session = {
    id:      Date.now(),
    date:    new Date().toLocaleString(),
    lang:    LANGS[curLang].name,
    emotion: emotion,
    kws:     kws,
    summary: summary || 'Session ended',
    msgs:    history.slice()
  };
  sessions.unshift(session);
  secureSet(SESSIONS_KEY, sessions.slice(0,MAX_HISTORY));
}

function buildHistorySummary(){
  const sessions = getSessions().slice(0,5);
  if(!sessions.length) return '';
  const lines = sessions.map(s=>`[${s.date}] Mood: ${s.emotion}. Topics: ${s.kws.join(', ')||'general'}. Summary: ${s.summary}`);
  return `\n\nPREVIOUS SESSION CONTEXT (last ${lines.length} sessions — use this to personalise your response):\n${lines.join('\n')}`;
}

function renderHistory(){
  const sessions = getSessions();
  const body = document.getElementById('hp-body');
  body.innerHTML='';

  // Mood trend chart
  if(sessions.length){
    const chart = document.createElement('div');
    chart.className='mood-chart';
    const recent = sessions.slice(0,7).reverse();
    const moodColors = {joy:'#7ab87a',sadness:'#64b5f6',anxiety:'#ffb74d',anger:'#e57373',neutral:'#bdbdbd'};
    const moodH = {joy:100,sadness:60,anxiety:75,anger:80,neutral:40};
    chart.innerHTML=`<div class="mood-chart-title">Mood trend (last ${recent.length} sessions)</div>
      <div class="mood-bars">
        ${recent.map(s=>`<div class="mood-bar-col">
          <div class="mood-bar" style="height:${moodH[s.emotion]||40}%;background:${moodColors[s.emotion]||'#bdbdbd'}"></div>
          <div class="mood-bar-lbl">${s.emotion.slice(0,3)}</div>
        </div>`).join('')}
      </div>`;
    body.appendChild(chart);
  }

  if(!sessions.length){
    const empty=document.createElement('div');
    empty.className='no-history';
    empty.textContent='No past sessions yet. Your history will appear here after your first chat.';
    body.appendChild(empty);
    return;
  }

  sessions.forEach(s=>{
    const card=document.createElement('div');
    card.className='session-card';
    const em={'joy':'😊','sadness':'😔','anxiety':'😰','anger':'😤','neutral':'😐'};
    card.innerHTML=`
      <div class="sc-date">${s.date} &nbsp;·&nbsp; ${s.lang}</div>
      <div class="sc-summary">${s.summary}</div>
      <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:6px">
        <span class="sc-mood">${em[s.emotion]||'😐'} ${s.emotion}</span>
        ${s.kws.slice(0,3).map(k=>`<span class="sc-mood"># ${k}</span>`).join('')}
      </div>`;
    body.appendChild(card);
  });

  const clr=document.createElement('button');
  clr.className='clear-alerts';clr.textContent='Clear history';
  clr.onclick=()=>{ localStorage.removeItem(SESSIONS_KEY); renderHistory(); };
  body.appendChild(clr);
}

function openHistory(){ renderHistory(); document.getElementById('history-panel').classList.add('open'); document.getElementById('overlay').classList.add('show'); }
function closeHistory(){ document.getElementById('history-panel').classList.remove('open'); document.getElementById('overlay').classList.remove('show'); }
function closePanels(){ closeHistory(); closeMonitor(); }

// ═══════════════════════════════════════════════════
//  SPEECH
// ═══════════════════════════════════════════════════
function buildRecog(lang){
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  if(!SR) return null;
  const r=new SR(); r.continuous=false; r.interimResults=true; r.lang=lang;
  r.onresult=e=>{ document.getElementById('inp').value=Array.from(e.results).map(r=>r[0].transcript).join(''); };
  r.onend=()=>{ listening=false; document.getElementById('mic-btn').classList.remove('listening');
    const v=document.getElementById('inp').value.trim(); if(v) sendMessage(); };
  r.onerror=e=>{ listening=false; document.getElementById('mic-btn').classList.remove('listening');
    if(e.error==='not-allowed') showErr('Mic permission denied. Allow mic access in Chrome.');
    else if(e.error!=='aborted') showErr('Mic error: '+e.error); };
  return r;
}
function toggleMic(){
  if(!recog) recog=buildRecog(curLang);
  if(!recog){ showErr('Speech recognition requires Chrome.'); return; }
  if(listening){ recog.stop(); return; }
  recog=buildRecog(curLang); hideErr(); recog.start(); listening=true;
  document.getElementById('mic-btn').classList.add('listening');
  document.getElementById('inp').placeholder='Listening in '+LANGS[curLang].name+'…';
  setTimeout(()=>{ document.getElementById('inp').placeholder=LANGS[curLang].ph; },8000);
}

function loadVoices(){ ttsVoices=window.speechSynthesis.getVoices(); }
window.speechSynthesis.onvoiceschanged=loadVoices;

function getBestVoice(lang){
  if(!ttsVoices.length) ttsVoices=window.speechSynthesis.getVoices();
  const tts=LANGS[lang]?.tts||'en-IN';
  return ttsVoices.find(v=>v.lang===tts)||ttsVoices.find(v=>v.lang.startsWith(tts.split('-')[0]))||ttsVoices.find(v=>v.lang.startsWith('en'))||null;
}
function speak(text,avEl){
  if(!ttsOn||!window.speechSynthesis) return;
  window.speechSynthesis.cancel();
  const u=new SpeechSynthesisUtterance(text);
  u.rate=0.90; u.pitch=1.05; u.volume=1.0;
  const v=getBestVoice(curLang); if(v) u.voice=v;
  if(avEl){ avEl.classList.add('speaking'); u.onend=()=>avEl.classList.remove('speaking'); u.onerror=()=>avEl.classList.remove('speaking'); }
  window.speechSynthesis.speak(u);
}
function toggleTTS(){
  ttsOn=!ttsOn;
  const b=document.getElementById('tts-btn');
  b.textContent=ttsOn?'🔊 Voice':'🔇 Muted'; b.classList.toggle('on',ttsOn);
  if(!ttsOn) window.speechSynthesis.cancel();
}

// ═══════════════════════════════════════════════════
//  LANGUAGE
// ═══════════════════════════════════════════════════
function setLang(btn){
  document.querySelectorAll('.lbtn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active'); curLang=btn.dataset.lang;
  document.getElementById('inp').placeholder=LANGS[curLang].ph;
  recog=buildRecog(curLang);
}

// ═══════════════════════════════════════════════════
//  SEND MESSAGE
// ═══════════════════════════════════════════════════
function setMood(btn,mood){
  document.querySelectorAll('.mb').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active'); sendChip('My current mood is: '+mood);
}
function sendChip(text){ document.getElementById('inp').value=text; sendMessage(); }

async function sendMessage(){
  const inp=document.getElementById('inp');
  const text=inp.value.trim();
  if(!text||isBusy) return;

  addMsg('user',text);
  history.push({role:'user',content:text});
  inp.value=''; inp.style.height='auto';

  let lastEmotion = runNLP(text);
  setBusy(true); hideErr();

  // Build system prompt — inject detected emotion so llama3 tailors its voice response
  const historySummary = buildHistorySummary();
  const emotionHint = `\n\nDETECTED EMOTION: The person appears to be feeling "${lastEmotion}". Tailor your warm, spoken response to this emotion and naturally weave in a relevant CBT technique as described above.`;
  const sysMsg = BASE_SYS
    + '\n\nLANGUAGE INSTRUCTION (CRITICAL): ' + LANGS[curLang].sys
    + emotionHint
    + historySummary;

  // Show context notice on first message if history exists
  if(history.length===1 && getSessions().length>0){
    const notice=document.createElement('div');
    notice.className='ctx-notice';
    notice.textContent=`📋 I remember our ${getSessions().length} previous session(s) — using that context to support you better today.`;
    document.getElementById('msgs').appendChild(notice);
  }

  try{
    const res=await fetch(OLLAMA_URL,{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ model:MODEL,
        messages:[{role:'system',content:sysMsg},...history],
        stream:false })
    });
    if(!res.ok) throw new Error('HTTP '+res.status);
    const data=await res.json();
    const reply=data.message?.content?.trim()||"I'm here with you. Tell me more.";
    setBusy(false);
    history.push({role:'assistant',content:reply});
    const av=addMsg('bot',reply);
    setStatus(true);
    speak(reply,av);
  }catch(err){
    setBusy(false);
    if(err.message.includes('fetch')||err.message.includes('Network')) setStatus(false);
    else showErr('Something went wrong — please try again.');
  }
}

function addMsg(role,text){
  const wrap=document.getElementById('msgs');
  const div=document.createElement('div'); div.className='msg '+(role==='user'?'user':'bot');
  const av=document.createElement('div'); av.className='av '+(role==='user'?'usr':'bot'); av.textContent=role==='user'?'You':'M';
  const bw=document.createElement('div'); bw.className='bwrap';
  const bub=document.createElement('div'); bub.className='bub'; bub.textContent=text;
  bw.appendChild(bub);
  if(role==='bot'){
    const rb=document.createElement('button'); rb.className='replay-btn'; rb.textContent='🔈 Replay';
    rb.onclick=()=>speak(text,av); bw.appendChild(rb);
  }
  div.appendChild(av); div.appendChild(bw); wrap.appendChild(div); scrollDown();
  return av;
}

function setBusy(v){
  isBusy=v;
  document.getElementById('typing').classList.toggle('show',v);
  document.getElementById('inp').disabled=v;
  document.getElementById('sbtn').disabled=v;
  document.getElementById('mic-btn').disabled=v;
  if(v) scrollDown();
}
function scrollDown(){ const c=document.getElementById('chat-wrap'); setTimeout(()=>c.scrollTo({top:c.scrollHeight,behavior:'smooth'}),50); }
function showErr(m){ const e=document.getElementById('err'); e.textContent=m; e.classList.add('show'); }
function hideErr(){ document.getElementById('err').classList.remove('show'); }

function clearChat(){
  saveSession();   // save before clearing
  history=[];
  document.querySelectorAll('#msgs .msg, #msgs .ctx-notice').forEach(m=>m.remove());
  document.getElementById('crisis-bar').classList.remove('show');
  document.getElementById('nlp-bar').classList.remove('visible');
  document.querySelectorAll('.mb').forEach(b=>b.classList.remove('active'));
  hideErr(); window.speechSynthesis.cancel();
}

// ═══════════════════════════════════════════════════
//  CONNECTION
// ═══════════════════════════════════════════════════
async function checkConn(){
  try{ const r=await fetch('http://localhost:11434/',{signal:AbortSignal.timeout(3000)}); setStatus(r.ok); }
  catch{ setStatus(false); }
}
function setStatus(ok){
  document.getElementById('sdot').className='sdot'+(ok?'':' off');
  document.getElementById('stxt').textContent=ok?'llama3 ready':'Ollama offline';
  if(!ok) showErr('Ollama is not running. Open a terminal and run:  ollama serve');
  else hideErr();
}

// ═══════════════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════════════
document.getElementById('inp').addEventListener('input',function(){
  this.style.height='auto'; this.style.height=Math.min(this.scrollHeight,110)+'px';
});
document.getElementById('inp').addEventListener('keydown',function(e){
  if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMessage();}
});

// Save session when page closes
window.addEventListener('beforeunload', saveSession);

recog=buildRecog(curLang);
checkConn();
loadVoices();
updateAlertBadge();
initLockScreen();
loadTherapyDataset();
</script>
