`;

// ═══════════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════════
let history    = [];          // current session messages
let isBusy     = false;
let ttsOn      = true;
let curLang    = 'en-IN';
let recog      = null;
let listening  = false;
let ttsVoices  = [];

// ── Session storage keys ──
const SESSIONS_KEY = 'mindease_sessions';
const ALERTS_KEY   = 'mindease_alerts';

// ═══════════════════════════════════════════════════
//  NLP
// ═══════════════════════════════════════════════════
const EMOTIONS = {
  joy:    ['happy','joy','excited','great','wonderful','love','grateful','glad','smile','positive','enjoy','சந்தோஷம்','மகிழ்ச்சி','खुश','प्रसन्न'],
  sadness:['sad','cry','depressed','hopeless','lonely','alone','grief','tears','miserable','worthless','துக்கம்','தனிமை','दुखी','उदास','अकेला'],
  anxiety:['anxious','worried','nervous','stress','panic','fear','scared','overwhelmed','tense','கவலை','பயம்','चिंता','घबराहट','डर'],
  anger:  ['angry','furious','frustrated','annoyed','rage','hate','mad','upset','கோபம்','गुस्सा','क्रोध'],
};
const STOP = new Set(['i','me','my','we','you','the','a','an','is','am','are','was','were','be','have','has','do','does','will','to','of','in','on','at','for','with','and','or','but','not','so','that','this','it','just','very','really','feel','feeling','im','ive','dont','cant','wont','please','help','want']);
const CRISIS_WORDS = [
  'suicide','kill myself','end my life','want to die','self harm','hurt myself',
  'no reason to live',"can't go on",'cant go on','end it all','not worth living',
  'how to hang','how to hang myself','hanging myself','overdose','cut myself',
  'jump off','want to end','take my life','உயிரை மாய்த்துக்க','जीवन समाप्त'
];

function detectEmotion(t){
  const l=t.toLowerCase(); let best='neutral',max=0;
  for(const [e,ws] of Object.entries(EMOTIONS)){const n=ws.filter(w=>l.includes(w)).length;if(n>max){max=n;best=e;}}
  return best;
}
function extractKW(t){
  return t.toLowerCase().replace(/[^\w\s]/g,'').split(/\s+/)
    .filter(w=>w.length>3&&!STOP.has(w)).slice(0,5);
}
function hasCrisis(t){return CRISIS_WORDS.some(k=>t.toLowerCase().includes(k));}

function runNLP(text){
  const emotion = detectEmotion(text);
  const crisis  = hasCrisis(text);
  const kws     = extractKW(text);
  const langName = LANGS[curLang].name;

  document.getElementById('crisis-bar').classList.toggle('show', crisis);

  const inner = document.getElementById('nlp-inner');
  inner.innerHTML='';
  const em={'joy':'😊','sadness':'😔','anxiety':'😰','anger':'😤','neutral':'😐'};
  mkPill(inner,`${em[emotion]||'😐'} ${emotion}`,`p-${emotion}`);
  mkPill(inner,`🗣 ${langName}`,'p-lang');
  kws.forEach(k=>mkPill(inner,`# ${k}`,'p-kw'));
  if(crisis) mkPill(inner,'⚠ crisis','p-crisis');
  document.getElementById('nlp-bar').classList.add('visible');

  if(crisis) triggerCrisisAlert(text, kws);
  return emotion;
}
function mkPill(el,txt,cls){
  const s=document.createElement('span');
  s.className=`pill ${cls}`;s.textContent=txt;el.appendChild(s);
}

// ═══════════════════════════════════════════════════
