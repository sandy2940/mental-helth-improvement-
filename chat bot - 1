  'hi-IN':{ name:'Hindi',   tts:'hi-IN',
    sys:'उपयोगकर्ता हिंदी में बोल रहे हैं। पूरी तरह हिंदी में जवाब दें।',
    ph:'हिंदी में टाइप करें…' },
